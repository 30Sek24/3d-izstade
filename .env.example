# Backend specific overrides (Bypasses RLS for system operations)
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_SERVICE_KEY="your-service-role-key"

# AI Providers
OPENAI_API_KEY="sk-your-openai-api-key"
